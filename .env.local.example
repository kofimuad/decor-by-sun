# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/decorbysun

# NextAuth
NEXTAUTH_SECRET=your_random_secret_string_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (single admin user)
ADMIN_EMAIL=sun@decorbysun.com
ADMIN_PASSWORD=your_secure_password

# Gmail SMTP (Nodemailer)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=decorbysun@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Business email that receives booking notifications
BUSINESS_EMAIL=sun@decorbysun.com

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Public site URL
NEXT_PUBLIC_SITE_URL=https://decorbysun.com
